  },
  "file_types": ["DEMO", "DRUG", "REAC", "OUTC", "RPSR", "THER", "INDI"],
  "paths": {
    "colab": {
      "project_root": "/content/drive/MyDrive/faers-data-pipeline",
      "raw": "/content/drive/MyDrive/faers-data-pipeline/data/raw",
      "bronze": "/content/drive/MyDrive/faers-data-pipeline/data/bronze",
      "silver": "/content/drive/MyDrive/faers-data-pipeline/data/silver",
      "gold": "/content/drive/MyDrive/faers-data-pipeline/data/gold"
    },
    "azure": {
      "storage_account": "stfaersproject",
      "raw_container": "raw",
      "processed_container": "processed",
      "presentation_container": "presentation"
